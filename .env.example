# 키움 REST API 자격증명 (이 파일은 예시용 — 실제 값은 .env.local 에 넣으세요)
# .env.local 은 .gitignore 에 등록되어 git/GitHub 에 올라가지 않습니다.
KIWOOM_APPKEY=여기에_앱키
KIWOOM_SECRET=여기에_시크릿키

# Supabase (Vercel 서버가 DB에 기록할 때 필요 — service_role 키는 절대 공개 금지)
SUPABASE_URL=https://nxvpipgvcrfkujbvjjak.supabase.co
SUPABASE_SERVICE_ROLE_KEY=여기에_service_role_키

# Gemini API (마켓스코프 이슈 탐지, 종목 차트 분석 자동 생성용)
GEMINI_API_KEY=여기에_Gemini_API_키
